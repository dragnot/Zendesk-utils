ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token

# ── Zendesk ───────────────────────────────────────────────────────────────────
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token

# ── Telegram (optional — used by sla_report.py --notify) ──────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Local FalkorDB (populate_local.py) ────────────────────────────────────────
FALKORDB_LOCAL_HOST=localhost
FALKORDB_LOCAL_PORT=6379

# ── Remote FalkorDB — Active graph (open + pending tickets) ───────────────────
FALKORDB_ACTIVE_HOST=your-active-falkordb-host
FALKORDB_ACTIVE_PORT=6379
FALKORDB_ACTIVE_USERNAME=falkordb
FALKORDB_ACTIVE_PASSWORD=your-active-password

# ── Remote FalkorDB — History graph (solved + closed tickets) ─────────────────
FALKORDB_HISTORY_HOST=your-history-falkordb-host
FALKORDB_HISTORY_PORT=6379
FALKORDB_HISTORY_USERNAME=falkordb
FALKORDB_HISTORY_PASSWORD=your-history-password
